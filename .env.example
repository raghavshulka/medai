# ─────────────────────────────────────────────────────────────
# medai — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# API server
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# PostgreSQL (Prisma) — local Postgres starts via `pnpm run db:up` (docker compose)
DATABASE_URL=postgresql://medai:medai@localhost:5432/medai?schema=public

# Redis — started via `pnpm run db:up` (docker compose)
REDIS_URL=redis://localhost:6379

# Auth (Better Auth) — generate a strong secret, e.g. `openssl rand -hex 32`
BETTER_AUTH_SECRET=change-me-better-auth-secret-please
BETTER_AUTH_URL=http://localhost:4000
# Better Auth Dash (hosted dashboard) — copy the key from your project in the
# Better Auth dashboard. Enables the dash() plugin + ownership verification.
BETTER_AUTH_API_KEY=

# AI providers (Vercel AI SDK)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Default provider: anthropic | openai
AI_DEFAULT_PROVIDER=anthropic

# Logging — fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Web app
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_URL=http://localhost:4000
