# ─────────────────────────────────────────────────────────────
# medai — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# API server
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# MongoDB — provide your own connection URL (Atlas, self-hosted, or the
# optional local Mongo in docker-compose.yml at mongodb://localhost:27017)
MONGODB_URI=mongodb://localhost:27017/medai

# Redis — started via `bun run db:up` (docker compose)
REDIS_URL=redis://localhost:6379

# Auth — generate strong values, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=change-me-access-secret-please
JWT_REFRESH_SECRET=change-me-refresh-secret-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# 2FA issuer label shown in authenticator apps
TOTP_ISSUER=MedAI

# AI providers (Vercel AI SDK)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Default provider: anthropic | openai
AI_DEFAULT_PROVIDER=anthropic

# Logging — fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Web app
NEXT_PUBLIC_API_URL=http://localhost:4000
