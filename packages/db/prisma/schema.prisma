// ─── Reporting ───

model Report {
  id           String         @id
  /// ref -> Organization
  tenantId     String
  organization Organization   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  reportType   ReportType
  category     ReportCategory
  status       ReportStatus?  @default(PENDING)
  format       ReportFormat?  @default(json)
  parameters   Json
  data         Json?
  summary      Json?
  /// embedded (required): { id, name }
  generatedBy  Json
  generatedAt  DateTime?
  expiresAt    DateTime?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, generatedAt])
  @@index([tenantId, reportType, status])
  // TODO: dotted-key index { "generatedBy.id": 1 } — cannot index inside Json
  // NOTE: original had a TTL index on expiresAt (expireAfterSeconds: 0); Prisma has no TTL support
  @@index([expiresAt])
  @@map("report")
}

// ─── Compliance ───

model AuditLog {
  id           String             @id
  /// ref -> Organization
  tenantId     String
  organization Organization       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  eventType    AuditEventType
  category     AuditEventCategory
  /// ref -> User
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  userName     String
  resourceType String?
  resourceId   String?
  action       AuditAction?
  ip           String?
  userAgent    String?
  sessionId    String?
  details      Json?
  before       Json?
  after        Json?
  hash         String
  previousHash String?
  timestamp    DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([tenantId, timestamp])
  @@index([tenantId, userId, timestamp])
  @@index([tenantId, resourceType, resourceId, timestamp])
  @@index([tenantId, category, timestamp])
  @@index([tenantId, eventType, timestamp])
  @@map("audit_log")
}

model AuditExport {
  id               String            @id
  /// ref -> Organization
  tenantId         String
  organization     Organization      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  status           AuditExportStatus @default(PENDING)
  format           AuditExportFormat @default(json)
  startDate        DateTime
  endDate          DateTime
  categories       String[]
  estimatedRecords Int?
  processedRecords Int?              @default(0)
  downloadUrl      String?
  errorMessage     String?
  /// ref -> User
  requestedBy      String
  requester        User              @relation(fields: [requestedBy], references: [id], onDelete: Restrict)
  completedAt      DateTime?
  expiresAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  // NOTE: original had a TTL index on expiresAt (expireAfterSeconds: 0); Prisma has no TTL support
  @@index([expiresAt])
  @@map("audit_export")
}

model Consent {
  id           String         @id
  /// ref -> Organization
  tenantId     String
  organization Organization   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  /// ref -> User
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  purpose      ConsentPurpose
  description  String?
  granted      Boolean
  version      String?        @default("1.0")
  source       ConsentSource
  ipAddress    String?
  userAgent    String?
  grantedAt    DateTime?
  withdrawnAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // ── back-relations ──
  history ConsentHistory[]

  @@unique([tenantId, userId, purpose])
  @@index([tenantId, userId])
  @@index([tenantId, purpose, granted])
  @@map("consent")
}

model ConsentHistory {
  id            String               @id
  /// ref -> Organization
  tenantId      String
  organization  Organization         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  /// ref -> Consent
