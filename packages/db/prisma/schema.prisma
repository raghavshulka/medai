generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MessageRole {
  system
  user
  assistant
}

// ───────────────────────── Better Auth ─────────────────────────

model User {
  id               String         @id
  name             String
  email            String         @unique
  emailVerified    Boolean        @default(false)
  image            String?
  /// Application role (additionalField on the Better Auth user).
  role             String         @default("patient")
  twoFactorEnabled Boolean?       @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  conversations    Conversation[]

  // ── Hely domain back-relations ──
  staff                        Staff[]
  auditLogs                    AuditLog[]
  auditExports                 AuditExport[]
  consents                     Consent[]
  consentHistory               ConsentHistory[]
  securityEvents               SecurityEvent[]
  dataSubjectRequests          DataSubjectRequest[] @relation("DataSubjectRequestUser")
  dataSubjectRequestsProcessed DataSubjectRequest[] @relation("DataSubjectRequestProcessedBy")
  keyRotations                 KeyRotation[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model TwoFactor {
  id          String @id
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret      String
  backupCodes String

  @@map("twoFactor")
}

model Jwks {
  id         String   @id
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())

  @@map("jwks")
}

// ───────────────────────── Domain ─────────────────────────

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String    @default("New conversation")
  provider  String    @default("anthropic")
  model     String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

