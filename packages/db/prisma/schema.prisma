// ─── Clinical ───

model Prescription {
  id                 String                @id
  /// ref -> Organization
  tenantId           String
  organization       Organization          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  prescriptionId     String
  /// ref -> Patient
  patientId          String
  patient            Patient               @relation(fields: [patientId], references: [id], onDelete: Restrict)
  /// ref -> Staff
  doctorId           String
  doctor             Staff                 @relation("PrescriptionDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  /// ref -> Appointment
  appointmentId      String?
  appointment        Appointment?          @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  diagnosis          String
  notes              String?
  /// embedded[]: { medicineId, name, genericName, dosage, frequency, duration, route, quantity Int, instructions, dispensed Boolean, dispensedQuantity Int }
  medicines          Json?
  status             PrescriptionStatus?   @default(PENDING)
  followUpDate       DateTime?
  /// ref -> PrescriptionTemplate
  templateId         String?
  template           PrescriptionTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  cancelledAt        DateTime?
  /// ref -> Staff
  cancelledBy        String?
  canceller          Staff?                @relation("PrescriptionCancelledBy", fields: [cancelledBy], references: [id], onDelete: SetNull)
  cancellationReason String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  // ── back-relations ──
  dispensings Dispensing[]

  @@unique([tenantId, prescriptionId])
  @@index([tenantId, patientId, createdAt])
  @@index([tenantId, doctorId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("prescription")
}

model PrescriptionTemplate {
  id           String       @id
  /// ref -> Organization
  tenantId     String
  organization Organization @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name         String
  category     String?
  condition    String?
  /// embedded[]: { medicineId, name, genericName, dosage, frequency, duration, route, instructions }
  medicines    Json?
  isSystem     Boolean?     @default(false)
  /// ref -> Staff
  createdBy    String?
  creator      Staff?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // ── back-relations ──
  prescriptions Prescription[]

  @@unique([tenantId, name])
  @@index([tenantId, category])
  @@map("prescription_template")
}

model Medicine {
  id           String           @id
  /// ref -> Organization
  tenantId     String
  organization Organization     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name         String
  genericName  String?
  code         String
  category     MedicineCategory
  type         MedicineType
  manufacturer String?
  strength     String?
  unit         String
  description  String?
  isActive     Boolean?         @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // ── back-relations ──
  inventory Inventory[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
  @@index([tenantId, genericName])
  @@index([tenantId, category, isActive])
  @@map("medicine")
}

model Inventory {
  id            String       @id
  /// ref -> Organization
  tenantId      String
  organization  Organization @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  /// ref -> Medicine
  medicineId    String
  medicine      Medicine     @relation(fields: [medicineId], references: [id], onDelete: Restrict)
  currentStock  Int?         @default(0)
  reorderLevel  Int?         @default(10)
  maxStock      Int?
  location      String?
  /// embedded[] (_id:true): { batchNumber, quantity Float, expiryDate DateTime, purchasePrice Float, receivedDate DateTime, supplier }
  batches       Json?
  lastRestocked DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // ── back-relations ──
  transactions InventoryTransaction[]

  @@unique([tenantId, medicineId])
  @@index([tenantId, currentStock, reorderLevel])
  // TODO: dotted-key index { "batches.expiryDate": 1 } — cannot index inside Json
  @@map("inventory")
}

model InventoryTransaction {
  id           String          @id
  /// ref -> Organization
  tenantId     String
  organization Organization    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  /// ref -> Inventory
  inventoryId  String
  inventory    Inventory       @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  type         TransactionType
  quantity     Float
  batchNumber  String?
  reference    String?
  reason       String?
  /// ref -> Staff
  performedBy  String
  performer    Staff           @relation(fields: [performedBy], references: [id], onDelete: Restrict)
  performedAt  DateTime
  createdAt    DateTime        @default(now())

  @@index([tenantId, inventoryId, performedAt])
  @@index([tenantId, type, performedAt])
  @@index([tenantId, performedAt])
  @@map("inventory_transaction")
}

model Dispensing {
  id               String            @id
  /// ref -> Organization
  tenantId         String
  organization     Organization      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  /// ref -> Prescription
  prescriptionId   String
  prescription     Prescription      @relation(fields: [prescriptionId], references: [id], onDelete: Restrict)
  status           DispensingStatus? @default(PENDING)
  /// ref -> Staff
  assignedTo       String?
  assignee         Staff?            @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  startedAt        DateTime?
  completedAt      DateTime?
  collectedAt      DateTime?
  /// embedded[]: { medicineId, dispensedQuantity Int, batchNumber, expiryDate DateTime, substituted Boolean, substituteNote, status MedicineDispensingStatus }
  medicines        Json?
  notes            String?
  patientCounseled Boolean?          @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([tenantId, prescriptionId])
  @@index([tenantId, status])
  @@index([tenantId, assignedTo, status])
  @@index([tenantId, createdAt])
  @@map("dispensing")
}

model LabOrder {
  id                   String          @id
  /// ref -> Organization
  tenantId             String
  organization         Organization    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  orderId              String
  /// ref -> Patient
  patientId            String
  patient              Patient         @relation(fields: [patientId], references: [id], onDelete: Restrict)
  /// ref -> Staff
  doctorId             String
  doctor               Staff           @relation("LabOrderDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  /// ref -> Appointment
  appointmentId        String?
  appointment          Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  /// ref -> Admission
  admissionId          String?
  admission            Admission?      @relation(fields: [admissionId], references: [id], onDelete: SetNull)
  /// embedded[]: { testId, testName, testCode, priority TestPriority, status LabOrderStatus, clinicalNotes, resultDetails { value, unit, normalRange, flag ResultFlag, interpretation } }
  tests                Json?
  status               LabOrderStatus? @default(ORDERED)
  /// embedded: { sampleType SampleType, collectedBy (ref Staff), collectedAt DateTime, sampleId, notes }
  sampleDetails        Json?
  /// ref -> Staff
  resultEnteredBy      String?
  resultEnterer        Staff?          @relation("LabOrderResultEnteredBy", fields: [resultEnteredBy], references: [id], onDelete: SetNull)
  resultEnteredAt      DateTime?
  resultNotes          String?
  /// ref -> Staff
  verifiedBy           String?
  verifier             Staff?          @relation("LabOrderVerifiedBy", fields: [verifiedBy], references: [id], onDelete: SetNull)
  verifiedAt           DateTime?
  verificationComments String?
  diagnosis            String?
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([tenantId, orderId])
  @@index([tenantId, patientId, createdAt])
  @@index([tenantId, doctorId, createdAt])
  @@index([tenantId, status])
  @@map("labOrder")
}

model TestCatalog {
  id              String             @id
  /// ref -> Organization
  tenantId        String
  organization    Organization       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name            String
