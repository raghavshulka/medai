// ═══════════════════════════ Models ═══════════════════════════

// ─── Core ───

model Organization {
  id                  String              @id
  name                String
  slug                String              @unique
  type                OrganizationType    @default(HOSPITAL)
  licenseNumber       String?             @unique
  /// embedded: { street, city, state, postalCode, country }
  address             Json?
  contactEmail        String
  contactPhone        String
  adminEmail          String
  adminPhone          String
  status              OrganizationStatus? @default(PENDING)
  pricingTier         PricingTier?        @default(FREE)
  dodoCustomerId      String?
  verificationToken   String?
  verificationExpires DateTime?
  /// embedded: { appName, logoUrl, faviconUrl, supportEmail, primaryColor, accentColor, customDomain }
  branding            Json?
  settings            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // ── back-relations ──
  patients              Patient[]
  staff                 Staff[]
  departments           Department[]
  roles                 Role[]
  counters              Counter[]
  appointments          Appointment[]
  admissions            Admission[]
  vitals                Vitals[]
  prescriptions         Prescription[]
  prescriptionTemplates PrescriptionTemplate[]
  medicines             Medicine[]
  inventory             Inventory[]
  inventoryTransactions InventoryTransaction[]
  dispensings           Dispensing[]
  labOrders             LabOrder[]
  testCatalogs          TestCatalog[]
  clinicalNotes         ClinicalNote[]
  medicalHistories      MedicalHistory[]
  problemLists          ProblemList[]
  telemedicineVisits    TelemedicineVisit[]
  reports               Report[]
  auditLogs             AuditLog[]
  auditExports          AuditExport[]
  consents              Consent[]
  consentHistory        ConsentHistory[]
  securityEvents        SecurityEvent[]
  dataSubjectRequests   DataSubjectRequest[]
  subscriptions         Subscription[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
  // TODO: dotted-key index { "branding.customDomain": 1 } (unique, sparse) — cannot index inside Json
  @@map("organization")
}

model Patient {
  id               String         @id
  /// ref -> Organization
  tenantId         String
  organization     Organization   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patientId        String
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           Gender
  bloodGroup       String?
  phone            String
  email            String?
  /// embedded: { street, city, state, postalCode, country }
  address          Json?
  /// embedded (required): { name, relationship, phone }
  emergencyContact Json
  photoUrl         String?
  patientType      PatientType
  /// ref -> Department
  departmentId     String?
  department       Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  /// ref -> Staff
  assignedDoctorId String?
  doctor           Staff?         @relation("PatientAssignedDoctor", fields: [assignedDoctorId], references: [id], onDelete: SetNull)
  status           PatientStatus? @default(ACTIVE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // ── back-relations ──
  appointments       Appointment[]
  admissions         Admission[]
  vitals             Vitals[]
  prescriptions      Prescription[]
  labOrders          LabOrder[]
  clinicalNotes      ClinicalNote[]
  medicalHistory     MedicalHistory[]
  problems           ProblemList[]
  telemedicineVisits TelemedicineVisit[]

  @@unique([tenantId, patientId])
  @@index([tenantId, phone])
  @@index([tenantId, email])
  @@index([tenantId, patientType, status])
  @@index([tenantId, departmentId])
  @@index([tenantId, assignedDoctorId])
  @@index([tenantId, firstName, lastName])
  @@index([tenantId, createdAt])
  @@map("patient")
}

model Staff {
  id                  String       @id
  /// ref -> Organization
  tenantId            String
  organization        Organization @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  /// ref -> User
  userId              String
  user                User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  employeeId          String
  firstName           String
  lastName            String
  phone               String?
  /// ref -> Department
  departmentId        String?
  department          Department?  @relation("DepartmentStaff", fields: [departmentId], references: [id], onDelete: SetNull)
  /// ref -> Role (scalar list; cannot be a Postgres relation FK — kept as scalar)
  roles               String[]
  specialization      String?
  shift               StaffShift?
  status              StaffStatus? @default(ACTIVE)
  lastLogin           DateTime?
  deactivatedAt       DateTime?
  passwordHistory     String[]
  forcePasswordChange Boolean?     @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // ── back-relations ──
  assignedPatients       Patient[]              @relation("PatientAssignedDoctor")
  headedDepartments      Department[]           @relation("DepartmentHead")
  appointmentsAsDoctor   Appointment[]          @relation("AppointmentDoctor")
  appointmentsCancelled  Appointment[]          @relation("AppointmentCancelledBy")
  appointmentsCreated    Appointment[]          @relation("AppointmentCreatedBy")
  admissionsAsDoctor     Admission[]            @relation("AdmissionDoctor")
  admissionsAdmitted     Admission[]            @relation("AdmissionAdmittedBy")
  admissionsDischarged   Admission[]            @relation("AdmissionDischargedBy")
  vitalsRecorded         Vitals[]
  prescriptionsAsDoctor  Prescription[]         @relation("PrescriptionDoctor")
  prescriptionsCancelled Prescription[]         @relation("PrescriptionCancelledBy")
  prescriptionTemplates  PrescriptionTemplate[]
  inventoryTransactions  InventoryTransaction[]
  dispensings            Dispensing[]
  labOrdersAsDoctor      LabOrder[]             @relation("LabOrderDoctor")
  labOrdersResultEntered LabOrder[]             @relation("LabOrderResultEnteredBy")
  labOrdersVerified      LabOrder[]             @relation("LabOrderVerifiedBy")
  clinicalNotesAuthored  ClinicalNote[]         @relation("ClinicalNoteAuthor")
  clinicalNotesSigned    ClinicalNote[]         @relation("ClinicalNoteSignedBy")
  problemsAdded          ProblemList[]
  telemedicineVisits     TelemedicineVisit[]
  subscriptionsCancelled Subscription[]

  @@unique([tenantId, userId])
  @@unique([tenantId, employeeId])
  @@index([tenantId, departmentId])
  @@index([tenantId, status])
  @@index([tenantId, roles])
  @@map("staff")
}

model Department {
  id             String            @id
  /// ref -> Organization
  tenantId       String
  organization   Organization      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name           String
  code           String
  description    String?
  type           DepartmentType
  /// ref -> Department
  parentId       String?
  parent         Department?       @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  /// ref -> Staff
  headId         String?
  head           Staff?            @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  location       String?
  /// embedded: { phone, email }
  contact        Json?
  /// embedded: weekly hours { monday..sunday: { start, end } }
  operatingHours Json?
  status         DepartmentStatus? @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // ── back-relations ──
  children     Department[]  @relation("DepartmentHierarchy")
  staff        Staff[]       @relation("DepartmentStaff")
  patients     Patient[]
  appointments Appointment[]
  admissions   Admission[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
  @@map("department")
}

model Role {
  id           String       @id
  /// ref -> Organization
  tenantId     String
  organization Organization @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name         String
  description  String?
  permissions  String[]
  isSystem     Boolean?     @default(false)
  isActive     Boolean?     @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("role")
}

model Counter {
  id           String       @id
  /// ref -> Organization
  tenantId     String
  organization Organization @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  /// free-form string to support dynamic counters (e.g., queue-{doctorId}-{date})
  type         String
  seq          Int?         @default(0)

  @@unique([tenantId, type])
  @@map("counter")
}

model Appointment {
  id                 String               @id
  /// ref -> Organization
  tenantId           String
  organization       Organization         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  appointmentNumber  String
  /// ref -> Patient
  patientId          String
  patient            Patient              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  /// ref -> Staff
  doctorId           String
  doctor             Staff                @relation("AppointmentDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  /// ref -> Department
  departmentId       String
  department         Department           @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  date               DateTime
  /// embedded (required): { start, end }
  timeSlot           Json
  type               AppointmentType
  priority           AppointmentPriority? @default(NORMAL)
  reason             String?
  notes              String?
  status             AppointmentStatus?   @default(SCHEDULED)
  queueNumber        Int?
  checkedInAt        DateTime?
  completedAt        DateTime?
  followUpRequired   Boolean?
  followUpDate       DateTime?
  cancelledAt        DateTime?
  /// ref -> Staff
  cancelledBy        String?
  canceller          Staff?               @relation("AppointmentCancelledBy", fields: [cancelledBy], references: [id], onDelete: SetNull)
  cancellationReason String?
  /// ref -> Staff
  createdBy          String?
  creator            Staff?               @relation("AppointmentCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // ── back-relations ──
  vitals        Vitals[]
  prescriptions Prescription[]
  labOrders     LabOrder[]
  clinicalNotes ClinicalNote[]

  @@unique([tenantId, appointmentNumber])
  @@index([tenantId, patientId, date])
  @@index([tenantId, doctorId, date])
  @@index([tenantId, departmentId, date])
  @@index([tenantId, date, status])
  @@index([tenantId, status])
  @@map("appointment")
}

model Admission {
  id                   String           @id
  /// ref -> Organization
  tenantId             String
  organization         Organization     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  admissionNumber      String
  /// ref -> Patient
  patientId            String
  patient              Patient          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  /// ref -> Staff
  doctorId             String
  doctor               Staff            @relation("AdmissionDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  /// ref -> Department
  departmentId         String
  department           Department       @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  admissionDate        DateTime
  dischargeDate        DateTime?
  bedNumber            String?
  roomNumber           String?
  ward                 String?
  admissionReason      String
  provisionalDiagnosis String?
  finalDiagnosis       String?
  status               AdmissionStatus? @default(ADMITTED)
  dischargeType        DischargeType?
  dischargeSummary     String?
  notes                String?
  /// ref -> Staff
  admittedBy           String?
  admitter             Staff?           @relation("AdmissionAdmittedBy", fields: [admittedBy], references: [id], onDelete: SetNull)
  /// ref -> Staff
  dischargedBy         String?
  discharger           Staff?           @relation("AdmissionDischargedBy", fields: [dischargedBy], references: [id], onDelete: SetNull)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // ── back-relations ──
  vitals        Vitals[]
  labOrders     LabOrder[]
  clinicalNotes ClinicalNote[]

  @@unique([tenantId, admissionNumber])
  @@index([tenantId, patientId, admissionDate])
  @@index([tenantId, doctorId, status])
  @@index([tenantId, departmentId, status])
  @@index([tenantId, status])
  @@index([tenantId, admissionDate])
  @@index([tenantId, bedNumber, roomNumber])
  @@map("admission")
}

model Vitals {
  id               String       @id
  /// ref -> Organization
  tenantId         String
  organization     Organization @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  /// ref -> Patient
  patientId        String
  patient          Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  /// ref -> Appointment
  appointmentId    String?
  appointment      Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  /// ref -> Admission
  admissionId      String?
  admission        Admission?   @relation(fields: [admissionId], references: [id], onDelete: SetNull)
  /// embedded: { value Float, unit TemperatureUnit }
  temperature      Json?
  /// embedded: { systolic Int, diastolic Int }
  bloodPressure    Json?
  heartRate        Int?
  respiratoryRate  Int?
  oxygenSaturation Int?
  /// embedded: { value Float, unit WeightUnit }
  weight           Json?
  /// embedded: { value Float, unit HeightUnit }
  height           Json?
  bmi              Float?
  /// embedded: { value Float, unit GlucoseUnit, timing GlucoseTiming }
  bloodGlucose     Json?
  painLevel        Int?
  notes            String?
  correctionReason String?
  /// embedded[]: { type, parameter, value Float, severity AlertSeverity }
  alerts           Json?
  /// ref -> Staff
  recordedBy       String
  recorder         Staff        @relation(fields: [recordedBy], references: [id], onDelete: Restrict)
  recordedAt       DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([tenantId, patientId, recordedAt])
  @@index([tenantId, appointmentId])
  @@index([tenantId, admissionId])
  @@index([tenantId, recordedAt])
  // TODO: dotted-key index { "alerts.severity": 1 } — cannot index inside Json
  @@map("vitals")
