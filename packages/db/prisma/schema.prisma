  /// embedded[]: { label, min Float, max Float, unit, gender (MALE|FEMALE|ALL, default ALL) }
  referenceRanges Json?
  status          TestCatalogStatus? @default(ACTIVE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@map("testCatalog")
}

model ClinicalNote {
  id             String             @id
  /// ref -> Organization
  tenantId       String
  organization   Organization       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  noteId         String             @unique
  /// ref -> Patient
  patientId      String
  patient        Patient            @relation(fields: [patientId], references: [id], onDelete: Restrict)
  /// ref -> Appointment
  encounterId    String?
  encounter      Appointment?       @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  /// ref -> Admission
  admissionId    String?
  admission      Admission?         @relation(fields: [admissionId], references: [id], onDelete: SetNull)
  type           ClinicalNoteType
  chiefComplaint String?
  subjective     String?
  objective      String?
  assessment     String?
  plan           String?
  content        String?
  /// embedded[]: { code, description, type DiagnosisType }
  diagnosis      Json?
  /// embedded[]: { code, description }
  procedures     Json?
  status         ClinicalNoteStatus @default(DRAFT)
  /// ref -> Staff
  authorId       String
  author         Staff              @relation("ClinicalNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  /// ref -> Staff
  signedBy       String?
  signer         Staff?             @relation("ClinicalNoteSignedBy", fields: [signedBy], references: [id], onDelete: SetNull)
  signedAt       DateTime?
  /// embedded[]: { reason, content, amendedBy (ref Staff), amendedAt DateTime }
  amendments     Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([tenantId, patientId, createdAt])
  @@index([tenantId, authorId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, encounterId])
  @@index([tenantId, updatedAt])
  @@map("clinical_notes")
}

model MedicalHistory {
